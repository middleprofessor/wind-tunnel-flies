jess[, treatment := substr(id,1,2)]
jess[, line := substr(id,1,3)]
jess[, sex := substr(id, 4,4)]
jess[, dial := substr(id, 5,6) |> as.integer()]
jess[, date := substr(id, 8,15)]
# performance measures
jess[, theta := ifelse(angle < 0,
-(angle + 180),
180-angle)]
jess[, wind_jess := 7.3888 * dial]
jess[, wind_jaw := 6.42237212 * dial]
jess[, disp.x := length * cos(theta * pi/180)]
jess[, disp.y := length * sin(theta * pi/180)]
jess[, wind.x := wind_jess / 30]
jess[, vel := sqrt((wind.x + disp.x)^2 + disp.y^2) * 30]
# first compute max within each id
jess_max_id <- jess[, .(vel_max = mean(vel),
N = .N),
by = .(date, treatment, line, sex, id)]
jess_sum <- jess_max_id[, .(mean_max = mean(vel_max),
N = .N),
by = .(date, sex, treatment, line)]
setorder(jess_sum, sex, date, treatment, line)
View(jess_sum)

## Jess Wheeler data

```{r jess-raw-import}

subfolder <- "burst speed/jess wheeler/sent from jess/raw"
subfolder_path <- here(data_folder, subfolder)

files <- list.files(
  path = subfolder_path,
  pattern = "\\.xlsx$",
  full.names = TRUE
)

filename <- "02.21.10 combined.xlsx"
in_path <- here(data_folder, subfolder, filename)

jess <- data.table(NULL)

for(i in 1:length(files)){
  in_path <- files[i]
  
  file_i <- read_xlsx(in_path,
                    range = "a1:c1000") |>
    clean_names() |>
    data.table() |>
    na.omit()
  # angle is flight angle in degrees from 1,0
  # length is flight distance over 1 frame
  colnames(file_i)[1] <- "id"
  file_i[, treatment := substr(id,1,2)]
  file_i[, line := substr(id,1,3)]
  file_i[, sex := substr(id, 4,4)]
  file_i[, dial := substr(id, 5,6) |> as.integer()]
  file_i[, date := substr(id, 8,15)]
  
  # performance measures
  file_i[, theta := ifelse(angle < 0,
                         -(angle + 180),
                         180-angle)]
  file_i[, wind_jess := 7.3888 * dial]
  file_i[, wind_jaw := 6.42237212 * dial]
  file_i[, disp.x := length * cos(theta * pi/180)]
  file_i[, disp.y := length * sin(theta * pi/180)]
  file_i[, wind.x := wind_jess / 30]
  file_i[, vel := sqrt((wind.x + disp.x)^2 + disp.y^2) * 30]
  
  jess <- rbind(jess, file_i)
  
}

```

```{r jess-summary}

# first compute max within each id
jess_max_id <- jess[, .(wind_max = mean(wind_jaw),
                        vel_max = mean(vel),
                        N = .N),
     by = .(date, treatment, line, sex, id)]

jess_sum <- jess_max_id[, .(wind_max = mean(wind_max),
                            vel_max = mean(vel_max),
                    N = .N), 
     by = .(date, sex, treatment, line)]
setorder(jess_sum, sex, treatment, line, date)
```



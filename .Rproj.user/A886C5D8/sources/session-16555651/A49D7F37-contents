Two lm models are fit

1. ~ treatment on line-aggregated data (n = 2) within sex
2. ~ treatment 

```{r simons-aggregate-model}
simons_agg <- simons[, .(vmax_2026 = mean(vmax_2026)), by = .(treatment, sex, random_line)]

lm1 <- lm(vmax_2026 ~ treatment * sex, data = simons_agg)
lm1_emm <- emmeans(lm1, specs = c("treatment", "sex"))
lm1_pairs <- contrast(lm1_emm,
                      method = "revpairwise",
                      simple = "each",
                      combine = TRUE,
                      adjust = "none") |>
  summary(infer = TRUE)

set.seed(5)
gg1 <- ggplot_the_model(lm1, lm1_emm, lm1_pairs,
                        y_label = "Speed (cm/s)",
                        effect_label = "Effect (cm/s)")

gg2 <- ggplot_the_response(lm1, lm1_emm, lm1_pairs,
                        y_label = "Max Burst Speed (cm/s)")

gg1
gg2
```


```{r simons-lmm-random-intercept}
lmm_all <- lmer(vmax_2026 ~ treatment * sex + room_temp + (1 | line), data = simons)

lmm_all_emm <- emmeans(lmm_all, specs = c("treatment", "sex"))

cn_m <- c(1,0,0,0)
aa_m <- c(0,1,0,0)
cn_f <- c(0,0,1,0)
aa_f <- c(0,0,0,1)
aa_contrast <- list(
  list(male = aa_m - cn_m),
  list(female = aa_f - cn_f)
)

lmm_all_pairs <- contrast(lmm_all_emm,
                      method = aa_contrast) |>
  summary(infer = TRUE)

lmm_all_emm
lmm_all_pairs

```


